{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oneshot.local/schemas/coherence-signoff.schema.json",
  "title": "Coherence Signoff",
  "description": "Validates the coherence_signoff block embedded in Visual Specification frontmatter.",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "verdict": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "numericCheck": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "value": {
          "type": "number"
        },
        "max_threshold": {
          "type": "number"
        },
        "verdict": {
          "$ref": "#/$defs/verdict"
        },
        "details": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["value", "max_threshold", "verdict", "details"]
    },
    "qualitativeCheck": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "value": {
          "type": "number"
        },
        "max_threshold": {
          "type": "number"
        },
        "verdict": {
          "$ref": "#/$defs/verdict"
        },
        "details": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["verdict", "details"]
    },
    "thresholdMap": {
      "type": "object",
      "additionalProperties": {
        "type": ["number", "integer", "boolean"]
      }
    },
    "thresholdResolution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "from_defaults": {
          "$ref": "#/$defs/thresholdMap"
        },
        "from_medium_override": {
          "$ref": "#/$defs/thresholdMap"
        },
        "from_preset_override": {
          "$ref": "#/$defs/thresholdMap"
        },
        "effective": {
          "$ref": "#/$defs/thresholdMap"
        }
      },
      "required": ["from_defaults", "from_medium_override", "from_preset_override", "effective"]
    }
  },
  "properties": {
    "reviewer_session_id": {
      "type": "string",
      "format": "uuid"
    },
    "artifact_set_json": {
      "type": "string",
      "minLength": 1
    },
    "coherence_report_path": {
      "type": "string",
      "minLength": 1
    },
    "coherence_report_sha256": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{64}$"
    },
    "applied_thresholds_version": {
      "type": "integer",
      "minimum": 1
    },
    "applied_thresholds_resolution": {
      "$ref": "#/$defs/thresholdResolution"
    },
    "documented_prior_thresholds_version_justification": {
      "description": "Required when using a prior thresholds version instead of the active version.",
      "type": "string",
      "minLength": 1
    },
    "set_palette_delta": {
      "$ref": "#/$defs/numericCheck"
    },
    "set_color_temp_variance": {
      "$ref": "#/$defs/numericCheck"
    },
    "set_type_discipline": {
      "$ref": "#/$defs/qualitativeCheck"
    },
    "set_lighting_vocab": {
      "$ref": "#/$defs/qualitativeCheck"
    },
    "set_motion_tempo": {
      "$ref": "#/$defs/qualitativeCheck"
    },
    "set_audio_mood": {
      "$ref": "#/$defs/qualitativeCheck"
    },
    "set_spatial_scale": {
      "$ref": "#/$defs/qualitativeCheck"
    },
    "per_slot_integration": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "passed": {
          "type": "integer",
          "minimum": 0
        },
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "verdict": {
          "$ref": "#/$defs/verdict"
        },
        "details": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["passed", "total", "verdict", "details"]
    },
    "reviewer_qualitative_assessment": {
      "type": "string",
      "minLength": 1
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "revise", "fail"]
    }
  },
  "required": [
    "reviewer_session_id",
    "artifact_set_json",
    "coherence_report_path",
    "coherence_report_sha256",
    "applied_thresholds_version",
    "applied_thresholds_resolution",
    "set_palette_delta",
    "set_color_temp_variance",
    "set_type_discipline",
    "set_lighting_vocab",
    "set_motion_tempo",
    "set_audio_mood",
    "set_spatial_scale",
    "per_slot_integration",
    "reviewer_qualitative_assessment",
    "verdict"
  ]
}
