{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oneshot.local/schemas/token-payload-video_animation.schema.json",
  "title": "Video Animation Token Payload",
  "description": "Validates the tokens block in manifest.json for video_animation visual specifications.",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "hexColor": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$"
    },
    "numberMap": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_-]*$"
      },
      "additionalProperties": {
        "type": "number"
      }
    },
    "typeStyle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "family": {
          "type": "string",
          "minLength": 1
        },
        "size": {
          "type": "number",
          "minimum": 1
        },
        "weight": {
          "type": [
            "string",
            "integer",
            "number"
          ]
        },
        "leading": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "tracking": {
          "type": "number"
        }
      },
      "required": [
        "family",
        "size",
        "weight",
        "leading",
        "tracking"
      ]
    },
    "timing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "easing": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "duration_ms",
        "easing"
      ]
    },
    "namedString": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "name",
        "value"
      ]
    }
  },
  "properties": {
    "frame_pacing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fps": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "frame_sample_interval_s": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "holds_ms": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "required": [
        "fps",
        "frame_sample_interval_s",
        "holds_ms"
      ]
    },
    "motion_curve": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/timing"
      },
      "minProperties": 1
    },
    "type_in_motion": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/typeStyle"
      },
      "minProperties": 1
    },
    "audio_bed": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target_lufs": {
          "type": "number"
        },
        "ducking_db": {
          "type": "number"
        },
        "waveform_notes": {
          "type": "string"
        }
      },
      "required": [
        "target_lufs",
        "ducking_db",
        "waveform_notes"
      ]
    },
    "color_grade": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "palette": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/hexColor"
          }
        },
        "contrast": {
          "type": "number"
        },
        "saturation": {
          "type": "number"
        },
        "temperature": {
          "type": "string"
        }
      },
      "required": [
        "palette",
        "contrast",
        "saturation",
        "temperature"
      ]
    },
    "transition_vocab": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "transitions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": [
        "transitions"
      ]
    }
  },
  "required": [
    "frame_pacing",
    "motion_curve",
    "type_in_motion",
    "audio_bed",
    "color_grade",
    "transition_vocab"
  ]
}
