{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oneshot.local/schemas/token-payload-3d_render.schema.json",
  "title": "3D Render Token Payload",
  "description": "Validates the tokens block in manifest.json for 3d_render visual specifications.",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "hexColor": {
      "type": "string",
      "pattern": "^#[0-9A-Fa-f]{6}$"
    },
    "numberMap": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_-]*$"
      },
      "additionalProperties": {
        "type": "number"
      }
    },
    "typeStyle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "family": {
          "type": "string",
          "minLength": 1
        },
        "size": {
          "type": "number",
          "minimum": 1
        },
        "weight": {
          "type": [
            "string",
            "integer",
            "number"
          ]
        },
        "leading": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "tracking": {
          "type": "number"
        }
      },
      "required": [
        "family",
        "size",
        "weight",
        "leading",
        "tracking"
      ]
    },
    "timing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "easing": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "duration_ms",
        "easing"
      ]
    },
    "namedString": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "name",
        "value"
      ]
    }
  },
  "properties": {
    "key_light_direction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "azimuth_deg": {
          "type": "number"
        },
        "elevation_deg": {
          "type": "number"
        },
        "intensity": {
          "type": "number",
          "minimum": 0
        }
      },
      "required": [
        "azimuth_deg",
        "elevation_deg",
        "intensity"
      ]
    },
    "fill_ratio": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ratio": {
          "type": "number",
          "minimum": 0
        }
      },
      "required": [
        "ratio"
      ]
    },
    "rim_strength": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "intensity": {
          "type": "number",
          "minimum": 0
        }
      },
      "required": [
        "intensity"
      ]
    },
    "ambient_color": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "color": {
          "$ref": "#/$defs/hexColor"
        }
      },
      "required": [
        "color"
      ]
    },
    "material_roughness": {
      "$ref": "#/$defs/numberMap"
    },
    "material_specular": {
      "$ref": "#/$defs/numberMap"
    },
    "post_treatment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "effects": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": [
        "effects"
      ]
    }
  },
  "required": [
    "key_light_direction",
    "fill_ratio",
    "rim_strength",
    "ambient_color",
    "material_roughness",
    "material_specular",
    "post_treatment"
  ]
}
